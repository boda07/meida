# Copia este ficheiro para `.env` e preenche a tua chave do TMDB.
# Obter em: https://www.themoviedb.org/settings/api  (API Read Access Token OU API Key v3)

# Chave v3 (mais simples). Usa esta OU o token v4 abaixo.
TMDB_API_KEY=

# Alternativa: token v4 (Bearer). Se preencheres este, tem prioridade sobre a chave v3.
TMDB_ACCESS_TOKEN=

# Porta do backend
PORT=5174

# Segredo para assinar tokens de login (JWT). Poe aqui uma string aleatoria.
JWT_SECRET=muda-isto-para-uma-string-aleatoria-longa

# Legendas: chave gratis da API do OpenSubtitles (https://www.opensubtitles.com/consumers)
OPENSUBTITLES_API_KEY=

# (Opcional) Extractor externo compativel com Consumet para streams sem anuncios.
# Arranca o Consumet com Docker (ver docker-compose.yml na raiz):
#     docker compose up -d consumet
# e depois descomenta a linha abaixo:
# EXTRACTOR_API_BASE=http://localhost:3000
EXTRACTOR_API_BASE=
